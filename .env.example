# ──────────────────────────────────────────────────────────────────────────
# inkform-docs — environment variables (monorepo reference)
#
# Each theme/example ships its own .env.example; this file documents the shared
# conventions. Copy a theme's .env.example to .env.local and fill in as needed.
# Nothing here is required to build or run a docs site — sensible defaults apply.
# ──────────────────────────────────────────────────────────────────────────

# Site URL — used for canonical/OG tags and sitemap. Defaults to localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Ask-AI assistant (built in, OFF by default) ───────────────────────────
# The "Ask AI" widget and the /api/ask route are fully implemented but gated
# behind this flag. They light up in a future release; leave OFF for now.
NEXT_PUBLIC_DOCS_AI_ENABLED=false

# Server-only config the /api/ask route reads WHEN the flag above is true.
# (Never prefix secrets with NEXT_PUBLIC_ — that would ship them to the browser.)
DOCS_AI_PROVIDER=anthropic
DOCS_AI_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=

# ── Optional: newsletter / analytics / reactions (bring-your-own-backend) ──
# Only needed if your theme renders <SubscribeForm>, <AnalyticsScript>, etc.
# NEWSLETTER_ENDPOINT=
# ANALYTICS_BASE_URL=
