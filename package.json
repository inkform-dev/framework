{
  "name": "freewrite-docs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source Next.js + MDX framework for documentation, API reference, blog, and changelog sites — with themes, examples, and a scaffolding CLI.",
  "license": "MIT",
  "author": "Charan",
  "homepage": "https://github.com/freewrite-cms/framework#readme",
  "repository": { "type": "git", "url": "git+https://github.com/freewrite-cms/framework.git" },
  "workspaces": [
    "packages/*",
    "templates/*",
    "examples/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build:examples": "npm run build --workspace=@freewrite-cms/example-pokeapi --workspace=@freewrite-cms/example-markdown"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prettier": "^3.5.1"
  }
}
