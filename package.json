{
  "name": "@devsforfun/freewrite-framework",
  "version": "0.1.0",
  "description": "GitHub-native content rendering framework — Next.js + MDX renderer for changelogs, blogs, and documentation. Reads the same freewrite.json / series.json / slug-history.json files the Freewrite CMS editor writes.",
  "license": "MIT",
  "author": "Charan",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./content": "./src/content.ts",
    "./nav": "./src/nav.ts",
    "./mdx": "./src/mdx.tsx",
    "./components": "./src/components.tsx",
    "./search": "./src/search.ts",
    "./search-dialog": "./src/search-dialog.tsx",
    "./subscribe-form": "./src/subscribe-form.tsx",
    "./analytics-script": "./src/analytics-script.tsx"
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "next-mdx-remote": "^5.0.0",
    "rehype-pretty-code": "^0.14.1",
    "remark-directive": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.24.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "typescript": "^5"
  }
}
