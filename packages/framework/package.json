{
  "name": "@inkform/framework",
  "version": "0.4.0",
  "description": "Standalone Next.js + MDX framework for documentation, API reference (OpenAPI), blog, and changelog sites. The rendering engine behind the inkform docs themes — usable on its own.",
  "license": "MIT",
  "author": "Charan",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inkform-dev/framework.git",
    "directory": "packages/framework"
  },
  "homepage": "https://github.com/inkform-dev/framework#readme",
  "bugs": {
    "url": "https://github.com/inkform-dev/framework/issues"
  },
  "keywords": [
    "mdx",
    "nextjs",
    "docs",
    "documentation",
    "openapi",
    "api-reference",
    "changelog",
    "blog",
    "static-site"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./content": "./src/content.ts",
    "./nav": "./src/nav.ts",
    "./openapi": "./src/openapi.ts",
    "./openapi-engine/nav": "./src/openapi-engine/nav.ts",
    "./openapi-engine/parse": "./src/openapi-engine/parse.ts",
    "./openapi-engine/markdown": "./src/openapi-engine/markdown.ts",
    "./openapi-engine/breaking-changes": "./src/openapi-engine/breaking-changes.ts",
    "./openapi-render": "./src/openapi-render/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./ai": "./src/ai/index.ts",
    "./llms-txt": "./src/llms-txt.ts",
    "./mdx": "./src/mdx.tsx",
    "./components": "./src/components.tsx",
    "./docs-shell": "./src/docs-shell.tsx",
    "./scalar-theme": "./src/scalar-theme.ts",
    "./search-dialog": "./src/search-dialog.tsx",
    "./pagefind-highlight": "./src/pagefind-highlight-mount.tsx",
    "./ask-ai": "./src/ask-ai.tsx",
    "./ai-tool-menu": "./src/ai-tool-menu.tsx",
    "./theme-toggle": "./src/theme-toggle.tsx",
    "./subscribe-form": "./src/subscribe-form.tsx",
    "./analytics-script": "./src/analytics-script.tsx",
    "./secondary-top-nav": "./src/secondary-top-nav.tsx",
    "./scrollable-top-nav": "./src/scrollable-top-nav.tsx",
    "./comments": "./src/comments.tsx"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "diff-openapi": "tsx bin/diff-openapi.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "next": ">=16",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/google": "^4.0.18",
    "@ai-sdk/openai": "^4.0.16",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@scalar/json-magic": "^0.12.19",
    "@scalar/openapi-parser": "^0.28.10",
    "@scalar/openapi-types": "^0.9.3",
    "@scalar/snippetz": "^0.9.23",
    "ai": "^7.0.31",
    "fuse.js": "^7.5.0",
    "gray-matter": "^4.0.3",
    "next-mdx-remote": "^6.0.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^1.24.0",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
